    <script>
        (function () {
            var input = document.getElementById('essent-help-search');
            if (!input) return;

            var cards = document.querySelectorAll('.essent-help-card');

            input.addEventListener('input', function () {
                var query = input.value.trim().toLowerCase();

                cards.forEach(function (card) {
                    var haystack = (
                        card.querySelector('.essent-help-card__title').textContent + ' ' +
                        card.querySelector('.essent-help-card__desc').textContent + ' ' +
                        (card.getAttribute('data-keywords') || '')
                    ).toLowerCase();

                    var match = query === '' || haystack.indexOf(query) !== -1;
                    card.classList.toggle('essent-help-card--hidden', !match);
                });
            });
        })();
    </script>

